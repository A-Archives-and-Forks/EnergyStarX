  <data name="DefaultProcessWhitelist" xml:space="preserve">
    <value>// Одне ім'я процесу на рядок
// Подвійна коса риска та вміст після неї в кожному рядку будуть ігноруватися
// Підтримуються символи підстановки "?" та "*"

// Не ми самі
EnergyStar.exe
EnergyStarX.exe
// Edge має режим ефективності
msedge.exe
WebViewHost.exe
// UWP Frame має спеціальну обробку, не повинен обмежуватися
ApplicationFrameHost.exe
// Вогнегасник не повинен спалахнути
taskmgr.exe
procmon.exe
procmon64.exe
// Віджети
Widgets.exe
// Системна оболонка
dwm.exe
explorer.exe
ShellExperienceHost.exe
StartMenuExperienceHost.exe
SearchHost.exe
sihost.exe
fontdrvhost.exe
LockApp.exe
TabTip.exe
// IME
ChsIME.exe
ctfmon.exe
// Системна служба - у них є власна обізнаність
csrss.exe
smss.exe
svchost.exe
// WUDF
WUDFRd.exe

// Firefox 108 тепер підтримується режим ефективності
firefox.exe</value>
