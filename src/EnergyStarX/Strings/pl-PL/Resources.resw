  <data name="DefaultProcessWhitelist" xml:space="preserve">
    <value>// Jedna nazwa procesu na wiersz
// Podwójny ukośnik i zawartość po nim w każdej linii będą ignorowane.
// Obsługuje symbole wieloznaczne "?" i "*"
    
// Zostawcie nas
EnergyStar.exe
EnergyStarX.exe
// Edge ma własną obsługę EcoQoS
msedge.exe
WebViewHost.exe
// Ramka UWP ma specjalną obsługę, nie powinna być dławiona
ApplicationFrameHost.exe
// "Gaśnica nie powinna się zapalić"
taskmgr.exe
procmon.exe
procmon64.exe
// Widżety
Widgets.exe
// Powłoka systemowa
dwm.exe
explorer.exe
ShellExperienceHost.exe
StartMenuExperienceHost.exe
SearchHost.exe
sihost.exe
fontdrvhost.exe
LockApp.exe
TabTip.exe
// IME
ChsIME.exe
ctfmon.exe
// Usługi systemowe - mają swoją świadomość
csrss.exe
smss.exe
svchost.exe
// WUDF
WUDFRd.exe

// Firefox od wersji 108 obsługuje Tryb wydajności
firefox.exe</value>
